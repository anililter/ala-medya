# Ala Medya — Production / Development Environment
# Bu dosyayı .env.local olarak kopyalayıp değerleri doldurun. .env.local asla commit edilmez.

# -----------------------------------------------------------------------------
# Zorunlu
# -----------------------------------------------------------------------------

# Veritabanı bağlantı dizesi (PostgreSQL). Prisma ve iletişim formu API'si için gerekli.
# Örnek: postgresql://user:password@host:5432/dbname?sslmode=require
# Neon/Supabase kullanıyorsanız pooler URL'inize ?pgbouncer=true ekleyin.
DATABASE_URL=

# Üretim sitenizin tam URL'i. SEO (canonical, JSON-LD) ve sitemap için kullanılır.
# Örnek: https://alamedya.com
NEXT_PUBLIC_SITE_URL=https://alamedya.com

# -----------------------------------------------------------------------------
# İsteğe bağlı (ileride kullanım için)
# -----------------------------------------------------------------------------

# Google Analytics 4 Measurement ID (örn: G-XXXXXXXXXX)
# NEXT_PUBLIC_GA_ID=

# Form / iletişim webhook veya harici API anahtarı (şu an form Prisma ile DB'ye yazıyor)
# CONTACT_WEBHOOK_URL=

# Admin paneli için güvenlik (mevcut auth session secret vb. için)
# NEXTAUTH_SECRET=
